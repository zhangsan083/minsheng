# Configuration Load Mode:  tencent, url, or auto
# Recommended: 'url' (safest, no keys exposed)
VITE_CONFIG_MODE=url

# Hot update interval (ms), 0 to disable (e.g. 5 minutes = 300000)
VITE_CONFIG_REFRESH_INTERVAL=300000

# Primary (COS) URLs for failover
# The app will try COS
VITE_CONFIG_URL_COS=https://test-1411818512.cos.ap-hongkong.myqcloud.com/config.json

# Legacy single URL (optional)
VITE_CONFIG_URL=

# ------------------------------------------------------------------
# Optional: SDK Mode (Not recommended for public H5)
# If you use mode='tencent', fill these below:
# ------------------------------------------------------------------

# VITE_TENCENT_SECRET_ID=your-secret-id
# VITE_TENCENT_SECRET_KEY=your-secret-key
# VITE_TENCENT_REGION=ap-guangzhou
# VITE_TENCENT_BUCKET=your-bucket-name-1250000000
