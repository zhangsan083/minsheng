# ==============================================
# 本地开发环境配置 (Development)
# ==============================================

# ----------------------------------------------
# 1. 本地调试模式 (Local Debugging)
# ----------------------------------------------
# true:  强制使用本地配置 (忽略远程 config.json)，使用下方 VITE_API_BASE_URL
# false: 尝试加载远程 config.json (模拟生产环境行为)
VITE_USE_LOCAL_CONFIG=false

# 本地直连后端 API 地址 (当 VITE_USE_LOCAL_CONFIG=true 时生效)
#生产环境默认接口路由
VITE_API_BASE_URL=http://43.135.95.88:28002/
#测试环境默认接口路由
# VITE_API_BASE_URL=http://43.129.68.128:18002/

# ----------------------------------------------
# 2. 远程配置加载 (Remote Config)
# 当 VITE_USE_LOCAL_CONFIG=false 时生效
# ----------------------------------------------
# 加载模式: url (推荐), aliyun, tencent, auto
VITE_CONFIG_MODE=url

# 远程配置文件的地址 (config.json)
# 生产环境配置
VITE_CONFIG_URL_COS=https://app-1418927162.cos.ap-hongkong.myqcloud.com/config.json
# 测试环境配置
# VITE_CONFIG_URL_COS=https://test-1411818512.cos.ap-hongkong.myqcloud.com/config.json
# 配置热更新间隔 (毫秒)，0 为禁用
VITE_CONFIG_REFRESH_INTERVAL=300000

# ----------------------------------------------
# 3. 功能开关
# ----------------------------------------------
VITE_ENABLE_TENCENT=true
# 旧版兼容地址 (可选)
VITE_CONFIG_URL=
 