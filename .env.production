# ==============================================
# 生产环境配置 (Production)
# ==============================================

# 生产环境标识

# ----------------------------------------------
# 1. 核心配置
# ----------------------------------------------
# 强制关闭本地模式，确保读取远程 config.json
VITE_USE_LOCAL_CONFIG=false

# ----------------------------------------------
# 2. 远程配置地址
# ----------------------------------------------
# 腾讯云 COS 地址 (存放 config.json 的地址)
# [注意] 当前配置的是测试环境 Bucket (test-1384352169)，上线前请确认是否需要替换为正式环境
VITE_CONFIG_URL_COS=https://app-1418927162.cos.ap-hongkong.myqcloud.com/config.json

# 备用/兼容地址
VITE_CONFIG_URL=

# ----------------------------------------------
# 3. 腾讯云 COS 配置
# ----------------------------------------------
VITE_ENABLE_TENCENT=true

# ----------------------------------------------
# 4. 其他设置
# ----------------------------------------------
# 自动刷新间隔 (5分钟)
VITE_CONFIG_REFRESH_INTERVAL=300000
