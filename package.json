{
  "name": "minsheng-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "vite build && node -e \"require('fs').rmSync('dist/ms',{recursive:true,force:true})\" && npx cap sync android",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "7.1.0",
    "@capacitor/cli": "7.1.0",
    "@capacitor/core": "7.1.0",
    "@capacitor/network": "^7.0.4",
    "@capacitor/status-bar": "^7.0.6",
    "axios": "^1.7.7",
    "cos-js-sdk-v5": "^1.8.3",
    "fast-xml-parser": "^5.5.9",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "vant": "^4.9.8",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@vitejs/plugin-legacy": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.26.0",
    "globals": "^15.9.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sass": "^1.77.4",
    "terser": "^5.46.0",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^6.1.6",
    "vue-eslint-parser": "^9.3.1"
  },
  "lint-staged": {
    "*.{js,vue,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "Android >= 5",
    "iOS >= 10",
    "ChromeAndroid >= 50",
    "Safari >= 10",
    "> 0.5%",
    "not dead"
  ]
}
